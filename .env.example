# Ollama (local LLM for CrewAI)
OLLAMA_MODEL=ollama/llama3.2:latest
OLLAMA_BASE_URL=http://localhost:11434

# OpenTelemetry → Jaeger (default when LOGFIRE_TOKEN is unset)
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://localhost:4318/v1/traces

# Optional: Pydantic Logfire for New Relic–style UI (https://logfire.pydantic.dev)
# LOGFIRE_TOKEN=pylf_...

# Demo behavior: slow + error on inventory for order #1842's SKU
INCIDENT_SLOW_SECONDS=2.5
INCIDENT_FAIL_SKU=SKU-DELAYED-42

# CrewAI / LLM tracing: prompts on spans by default. Set false to redact content.
# TRACELOOP_TRACE_CONTENT=false
